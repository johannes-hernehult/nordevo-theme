{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "color": {
            "defaultPalette": false,
            "defaultGradients": false,
            "gradients": [],
            "palette": [
                { "slug": "nord-950", "color": "#0b1622", "name": "Nord 950" },
                { "slug": "nord-900", "color": "#14283e", "name": "Nord 900" },
                { "slug": "nord-800", "color": "#23364a", "name": "Nord 800" },
                { "slug": "nord-700", "color": "#334457", "name": "Nord 700" },
                { "slug": "nord-600", "color": "#425263", "name": "Nord 600" },
                { "slug": "nord-500", "color": "#586e82", "name": "Nord 500" },
                { "slug": "nord-400", "color": "#6e8aa1", "name": "Nord 400" },
                { "slug": "nord-300", "color": "#85a7c1", "name": "Nord 300" },
                { "slug": "nord-200", "color": "#9bc3e0", "name": "Nord 200" },
                { "slug": "nord-100", "color": "#b1dfff", "name": "Nord 100" },
                { "slug": "nord-50",  "color": "#e0f2ff", "name": "Nord 50"  }
            ]
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                { "slug": "1",  "size": "0.25rem", "name": "1"  },
                { "slug": "2",  "size": "0.5rem",  "name": "2"  },
                { "slug": "3",  "size": "0.75rem", "name": "3"  },
                { "slug": "4",  "size": "1rem",    "name": "4"  },
                { "slug": "6",  "size": "1.5rem",  "name": "6"  },
                { "slug": "8",  "size": "2rem",    "name": "8"  },
                { "slug": "12", "size": "3rem",    "name": "12" },
                { "slug": "16", "size": "4rem",    "name": "16" }
            ],
            "units": [ "px", "rem", "em", "%" ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fontSizes": [
                { "slug": "xs",  "size": "0.75rem",  "name": "XS"  },
                { "slug": "sm",  "size": "0.875rem", "name": "SM"  },
                { "slug": "md",  "size": "1rem",     "name": "MD"  },
                { "slug": "lg",  "size": "1.125rem", "name": "LG"  },
                { "slug": "xl",  "size": "1.25rem",  "name": "XL"  },
                { "slug": "2xl", "size": "1.5rem",   "name": "2XL" },
                { "slug": "3xl", "size": "1.875rem", "name": "3XL" },
                { "slug": "4xl", "size": "2.25rem",  "name": "4XL" }
            ]
        },
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1400px"
        }
    },
    "styles": {
        "typography": {
            "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif"
        }
    }
}
